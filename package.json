{
  "name": "lmnt",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo dev --filter=@lmnt/api --filter=@lmnt/dashboard --filter=@lmnt/worker",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier -w .",
    "db:migrate": "pnpm -C packages/database prisma migrate dev",
    "db:generate": "pnpm -C packages/database prisma generate",
    "db:studio": "pnpm -C packages/database prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}

