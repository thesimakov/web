// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE_TRIAL
  PRO
  PREMIUM
}

enum BillingPaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

/// Пользователь (заготовка под auth; сайты пока ссылаются по строковому user_id).
model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  /// Квота AI-токенов (внутренняя валюта продукта, не USD).
  tokenBalance Int      @default(0) @map("token_balance")
  planType     PlanType @default(FREE_TRIAL) @map("plan_type")
  createdAt    DateTime @default(now()) @map("created_at")

  billingTransactions BillingTransaction[]

  @@map("users")
}

/// Платёж и начисление токенов (только сервер / webhook).
model BillingTransaction {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  plan              PlanType
  tokensAdded       Int                  @map("tokens_added")
  paymentProvider   String               @map("payment_provider")
  status            BillingPaymentStatus
  /// Сумма в минимальных единицах валюты (центах), если применимо.
  amountPaidMinor   Int?                 @map("amount_paid_minor")
  /// Идемпотентность: id провайдера (OpenRouter / Stripe и т.д.).
  externalPaymentId String?              @unique @map("external_payment_id")
  idempotencyKey    String?              @unique @map("idempotency_key")
  createdAt         DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("billing_transactions")
}

/// Проект пользователя (группа сайтов; userId — внешний идентификатор до полноценного auth).
model Project {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  sites     Site[]

  @@index([userId])
  @@map("projects")
}

/// Сохранённый сайт: сырой промпт, JSON-схема UI и опубликованный URL.
model Site {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  prompt       String         @db.Text
  schemaJson   Json           @map("schema_json")
  createdAt    DateTime       @default(now()) @map("created_at")
  publishedUrl String?        @map("published_url")
  projectId    String?        @map("project_id")
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  versions     SiteVersion[]

  @@index([userId])
  @@index([projectId])
  @@map("sites")
}

/// История версий схемы для сайта (SaaS / откаты).
model SiteVersion {
  id         String   @id @default(cuid())
  siteId     String   @map("site_id")
  version    Int
  prompt     String?  @db.Text
  schemaJson Json     @map("schema_json")
  createdAt  DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, version])
  @@index([siteId])
  @@map("site_versions")
}

/// Запись генерации (аудит, квоты).
model Generation {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  siteId         String?  @map("site_id")
  promptSnapshot String   @map("prompt_snapshot") @db.Text
  usedFallback   Boolean  @default(false) @map("used_fallback")
  status         String   @default("completed")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("generations")
}

/// Учёт использования (квоты / биллинг).
model UsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  kind      String
  units     Int      @default(1)
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("usage_logs")
}
