# Пример переменных окружения для локальной разработки.
# Скопируй в `.env` и заполни значения.

# --- LLM (RouterAI) ---
# Документация: https://routerai.ru/docs/guides
# Endpoint: https://routerai.ru/api/v1
LLM_PROVIDER=routerai
ROUTERAI_API_KEY=PASTE_YOUR_ROUTERAI_KEY_HERE
ROUTERAI_BASE_URL=https://routerai.ru/api/v1

# (опционально) Явная модель; если пусто — берётся дефолт для провайдера
# LLM_MODEL=

# --- Demo user (без auth) ---
DEMO_USER_ID=local-demo
PUBLIC_DEMO_USER_ID=local-demo

# --- Database (Postgres) ---
# Если используешь `docker-compose.yml` в корне, Postgres доступен на `localhost:55433`
# и креды по умолчанию: lmnt / lmnt, база: lmnt
DATABASE_URL=postgresql://lmnt:lmnt@localhost:55433/lmnt

