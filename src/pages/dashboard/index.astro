---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SiteHeader } from "@/components/marketing/site-header";
import { getDemoUserId } from "@/lib/env.server";
import { prisma } from "@/lib/prisma";

const userId = getDemoUserId();
let sites: { id: string; prompt: string; createdAt: Date }[] = [];
let dbUnavailable: string | null = null;
try {
  sites = await prisma.site.findMany({
    where: { userId },
    orderBy: { createdAt: "desc" },
  });
} catch (e) {
  dbUnavailable =
    e instanceof Error ? e.message : "База данных недоступна (DATABASE_URL не задан)";
}
---

<BaseLayout title="Мои сайты — Lemnity">
  <SiteHeader />
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold text-white">Мои сайты</h1>
        <p class="mt-1 text-sm text-zinc-500">
          Демо-кабинет без логина. Пользователь:{" "}
          <code class="text-zinc-400">{userId}</code> — задай тот же id в{" "}
          <code class="text-zinc-400">DEMO_USER_ID</code> /{" "}
          <code class="text-zinc-400">PUBLIC_DEMO_USER_ID</code>
        </p>
      </div>
      <a
        href="/editor"
        class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium text-white hover:bg-violet-500"
      >
        Новая генерация
      </a>
    </div>

    {dbUnavailable ? (
      <div class="mt-8 rounded-2xl border border-border bg-card px-4 py-4 text-sm text-muted-foreground">
        <p class="font-medium text-foreground">Дашборд запущен, но БД не подключена.</p>
        <p class="mt-2">
          Задай переменную окружения <code class="text-foreground/70">DATABASE_URL</code> и
          выполни миграции Prisma, чтобы увидеть сохранённые сайты.
        </p>
        <details class="mt-3">
          <summary class="cursor-pointer select-none text-foreground/80">
            Детали ошибки
          </summary>
          <pre class="mt-2 overflow-auto whitespace-pre-wrap rounded-xl bg-background/60 p-3 text-xs text-foreground/70">{dbUnavailable}</pre>
        </details>
      </div>
    ) : null}

    {
      sites.length === 0 ? (
        <p class="mt-10 text-center text-zinc-500">
          Пока нет сохранённых сайтов. Сгенерируй в{" "}
          <a href="/editor" class="text-violet-400 underline">
            редакторе
          </a>{" "}
          с галочкой «Сохранить».
        </p>
      ) : (
        <ul class="mt-8 space-y-3">
          {sites.map((s) => (
            <li class="rounded-xl border border-white/10 bg-zinc-900/50 px-4 py-3">
              <a
                href={`/editor?site=${s.id}`}
                class="font-medium text-white hover:text-violet-300"
              >
                {s.prompt.length > 100 ? `${s.prompt.slice(0, 100)}…` : s.prompt}
              </a>
              <p class="mt-1 text-xs text-zinc-500">
                {s.createdAt.toLocaleString("ru-RU")} · id:{" "}
                <code class="text-zinc-400">{s.id}</code>
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
